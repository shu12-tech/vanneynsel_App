{
  "cli": {
    "version": ">= 16.19.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },

    "acceptance-apk-unpinned": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "false",
        "EXPO_PUBLIC_APP_ENV": "acceptance"
      }
    },

    "acceptance-apk-pinned": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "true",
        "EXPO_PUBLIC_APP_ENV": "acceptance"
      }
    },

    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "true",
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
