{
  "cli": {
    "version": ">= 16.19.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://backend.mijnvirtueleassistent.nl/Boundaryless_API",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://backend.mijnvirtueleassistent.nl/Boundaryless_API/ws",
        "EXPO_PUBLIC_AGENT_ID": "87585267-ba27-4a3f-ba27-38347b39738a",
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "false",
        "EXPO_PUBLIC_APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://backend.mijnvirtueleassistent.nl/Boundaryless_API",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://backend.mijnvirtueleassistent.nl/Boundaryless_API/ws",
        "EXPO_PUBLIC_AGENT_ID": "87585267-ba27-4a3f-ba27-38347b39738a",
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "false",
        "EXPO_PUBLIC_APP_ENV": "preview"
      }
    },
    "acceptance-apk-unpinned": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://backend.mijnvirtueleassistent.nl/Boundaryless_API",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://backend.mijnvirtueleassistent.nl/Boundaryless_API/ws",
        "EXPO_PUBLIC_AGENT_ID": "87585267-ba27-4a3f-ba27-38347b39738a",
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "false",
        "EXPO_PUBLIC_APP_ENV": "acceptance"
      }
    },
    "acceptance-apk-pinned": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://backend.mijnvirtueleassistent.nl/Boundaryless_API",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://backend.mijnvirtueleassistent.nl/Boundaryless_API/ws",
        "EXPO_PUBLIC_AGENT_ID": "87585267-ba27-4a3f-ba27-38347b39738a",
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "true",
        "EXPO_PUBLIC_APP_ENV": "acceptance"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://backend.mijnvirtueleassistent.nl/Boundaryless_API",
        "EXPO_PUBLIC_WS_BASE_URL": "wss://backend.mijnvirtueleassistent.nl/Boundaryless_API/ws",
        "EXPO_PUBLIC_AGENT_ID": "87585267-ba27-4a3f-ba27-38347b39738a",
        "EXPO_PUBLIC_ENABLE_SSL_PINNING": "true",
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
